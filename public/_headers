# Cache static assets aggressively — Astro adds content hashes to filenames
# so cache-busting happens automatically on rebuild.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts, images, favicon
/favicon.svg
  Cache-Control: public, max-age=604800

/favicon.ico
  Cache-Control: public, max-age=604800

/og-default.png
  Cache-Control: public, max-age=604800

# HTML pages should revalidate (SSR pages won't hit this, but static ones will)
/*.html
  Cache-Control: public, max-age=0, must-revalidate
