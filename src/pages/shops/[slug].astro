---
/*
  [slug].astro — dynamic route for individual shop pages.

  File-based dynamic routing in Astro works like Next.js:
    src/pages/shops/[slug].astro  →  /shops/stylebymia, /shops/techfinds-uk, etc.

  getStaticPaths() tells Astro at build time: "here are ALL the slugs
  you need to generate pages for." It fetches every approved shop from
  Supabase and creates a static HTML page for each one.

  This is the equivalent of getStaticPaths + getStaticProps in Next.js.
  Each shop gets its own indexable URL — this is what ranks in Google.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { platformDisplayNames, platformColours } from '../../lib/types';
import type { Shop } from '../../lib/types';

export async function getStaticPaths() {
  const { data } = await supabase
    .from('shops')
    .select('*')
    .eq('status', 'approved');

  const shops = (data ?? []) as Shop[];

  return shops.map(shop => ({
    params: { slug: shop.slug },
    props: { shop },
  }));
}

const { shop } = Astro.props as { shop: Shop };
const displayName = platformDisplayNames[shop.platform];
const colour = platformColours[shop.platform];

/*
  JSON-LD structured data — tells Google "this page is about a specific store."
  This is Schema.org markup. Google uses it to create rich search results
  (store name, description, platform shown directly in search).

  You'll see this used on product pages, recipes, events, etc. across the web.
  It's invisible to users but critical for SEO.
*/
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": shop.name,
  "description": shop.description ?? `${shop.name} on ${displayName}`,
  "url": shop.shop_url,
  "sameAs": [shop.shop_url],
};
---

<BaseLayout
  title={`${shop.name} — ${displayName}`}
  description={shop.description ?? `Discover ${shop.name} on ${displayName}. Browse products, follow the creator, and shop directly.`}
  ogType="profile"
>
  <!-- JSON-LD goes into the <head> via the named slot -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="max-w-3xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-900">Home</a>
      <span class="mx-2">›</span>
      <a href="/shops" class="hover:text-gray-900">Shops</a>
      <span class="mx-2">›</span>
      <span class="text-gray-900">{shop.name}</span>
    </nav>

    <div class="bg-white rounded-xl border border-gray-200 p-8">
      <div class="flex items-start justify-between mb-4">
        <h1 class="text-3xl font-bold">{shop.name}</h1>
        <span class={`text-sm px-3 py-1 rounded-full font-medium ${colour}`}>
          {displayName}
        </span>
      </div>

      {shop.description && (
        <p class="text-gray-600 text-lg mb-6">{shop.description}</p>
      )}

      <div class="flex flex-wrap gap-4 mb-8 text-sm text-gray-500">
        <span class="flex items-center gap-1">
          Category: <strong class="text-gray-900">{shop.category}</strong>
        </span>
        {shop.followers && (
          <span class="flex items-center gap-1">
            Followers: <strong class="text-gray-900">{shop.followers}</strong>
          </span>
        )}
      </div>

      <a
        href={`/go/${shop.slug}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition"
      >
        Visit Shop on {displayName} ↗
      </a>
    </div>
  </section>
</BaseLayout>
