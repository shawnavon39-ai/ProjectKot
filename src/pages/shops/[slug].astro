---
/*
  [slug].astro — dynamic route for individual shop pages.

  File-based dynamic routing in Astro works like Next.js:
    src/pages/shops/[slug].astro  →  /shops/stylebymia, /shops/techfinds-uk, etc.

  Server-rendered (prerender = false) so:
    1. New shops appear instantly after approval — no rebuild needed
    2. Env vars are available at runtime (Cloudflare Workers)
    3. Each request takes ~50ms at the edge — still very fast

  This is the equivalent of getServerSideProps in Next.js.
  Each shop gets its own indexable URL — this is what ranks in Google.
*/
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewForm from '../../components/ReviewForm';
import ShopCard from '../../components/ShopCard.astro';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../../lib/supabase';
import { platformDisplayNames, platformColours } from '../../lib/types';
import type { Shop } from '../../lib/types';

const supabase = getSupabase(env);
const { slug } = Astro.params;

const { data } = await supabase
  .from('shops')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'approved')
  .single();

if (!data) {
  return Astro.redirect('/shops', 307);
}

const shop = data as Shop;
const displayName = platformDisplayNames[shop.platform];
const colour = platformColours[shop.platform];

// Fetch approved reviews for this shop
const { data: reviewData } = await supabase
  .from('reviews')
  .select('*')
  .eq('shop_id', shop.id)
  .eq('status', 'approved')
  .order('created_at', { ascending: false });

const reviews = reviewData ?? [];

// Related: same platform, same category preferred, exclude current shop
const { data: relatedData } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .eq('platform', shop.platform)
  .neq('id', shop.id)
  .order('avg_rating', { ascending: false })
  .limit(4);

const related = (relatedData ?? []) as Shop[];

const avgRating = reviews.length > 0
  ? (reviews.reduce((sum: number, r: any) => sum + r.rating, 0) / reviews.length)
  : 0;

/*
  JSON-LD structured data — tells Google "this page is about a specific store."
  This is Schema.org markup. Google uses it to create rich search results
  (store name, description, platform shown directly in search).

  You'll see this used on product pages, recipes, events, etc. across the web.
  It's invisible to users but critical for SEO.
*/
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": shop.name,
  "description": shop.description ?? `${shop.name} on ${displayName}`,
  "url": shop.shop_url,
  "sameAs": [shop.shop_url],
  ...(reviews.length > 0 && {
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": avgRating.toFixed(1),
      "reviewCount": reviews.length,
      "bestRating": 5,
      "worstRating": 1,
    },
  }),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://pickyour.shop" },
    { "@type": "ListItem", "position": 2, "name": "Shops", "item": "https://pickyour.shop/shops" },
    { "@type": "ListItem", "position": 3, "name": shop.name },
  ],
};
---

<BaseLayout
  title={`${shop.name} — ${displayName}`}
  description={shop.description ?? `Discover ${shop.name} on ${displayName}. Browse products, follow the creator, and shop directly.`}
  ogType="profile"
>
  <!-- JSON-LD goes into the <head> via the named slot -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <section class="max-w-3xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-slate-900 transition">Home</a>
      <span class="mx-2">›</span>
      <a href="/shops" class="hover:text-slate-900 transition">Shops</a>
      <span class="mx-2">›</span>
      <span class="text-slate-900">{shop.name}</span>
    </nav>

    <div class="bg-white rounded-xl shadow-sm p-8">
      <div class="flex items-start justify-between mb-4">
        <div class="flex items-center gap-2">
          <h1 class="text-3xl font-bold text-slate-900">{shop.name}</h1>
          {shop.verified && (
            <span title="Verified shop" class="text-violet-600 flex items-center" aria-label="Verified">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6">
                <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
              </svg>
            </span>
          )}
        </div>
        <span class={`text-sm px-3 py-1 rounded-full font-medium ${colour}`}>
          {displayName}
        </span>
      </div>

      {shop.description && (
        <p class="text-slate-600 text-lg mb-6">{shop.description}</p>
      )}

      <div class="flex flex-wrap gap-4 mb-8 text-sm text-slate-500">
        <span class="flex items-center gap-1">
          Category: <strong class="text-slate-900">{shop.category}</strong>
        </span>
        {shop.followers && (
          <span class="flex items-center gap-1">
            Followers: <strong class="text-slate-900">{shop.followers}</strong>
          </span>
        )}
      </div>

      <a
        href={`/go/${shop.slug}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-6 py-3 bg-violet-600 text-white rounded-lg font-semibold hover:bg-violet-700 transition shadow-sm"
      >
        Visit Shop on {displayName} ↗
      </a>

      {avgRating > 0 && (
        <div class="mt-6 pt-6 border-t border-slate-100 flex items-center gap-2 text-sm text-slate-600">
          <span class="text-amber-500 text-lg">{'★'.repeat(Math.round(avgRating))}{'☆'.repeat(5 - Math.round(avgRating))}</span>
          <span>{avgRating.toFixed(1)} out of 5</span>
          <span class="text-slate-400">·</span>
          <span>{reviews.length} {reviews.length === 1 ? 'review' : 'reviews'}</span>
        </div>
      )}
    </div>

    <!-- Reviews section -->
    <div class="mt-8">
      <h2 class="text-xl font-bold text-slate-900 mb-4">Reviews</h2>

      {reviews.length > 0 ? (
        <div class="space-y-4 mb-8">
          {reviews.map((review: any) => (
            <div class="bg-white rounded-xl shadow-sm p-5">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                  <span class="font-medium text-sm text-slate-900">{review.display_name}</span>
                  <span class="text-amber-500 text-sm">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}</span>
                </div>
                <time class="text-xs text-slate-400" datetime={review.created_at}>
                  {new Date(review.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
              </div>
              <p class="text-sm text-slate-700">{review.body}</p>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500 mb-8">No reviews yet — be the first!</p>
      )}

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Leave a Review</h3>
        <ReviewForm shopId={shop.id} supabaseUrl={env.PUBLIC_SUPABASE_URL} supabaseAnonKey={env.PUBLIC_SUPABASE_ANON_KEY} client:only="react" />
      </div>
    </div>

    <!-- Related shops -->
    {related.length > 0 && (
      <div class="mt-12">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-slate-900">More {displayName} shops</h2>
          <a href={`/shops?platform=${shop.platform}`} class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {related.map(s => <ShopCard shop={s} />)}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
