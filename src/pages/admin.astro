---
/*
  admin.astro — server-rendered admin page for approving/rejecting shops.

  prerender = false tells Astro: "Don't generate this at build time.
  Run it on the server for every request instead."

  This is like the difference between:
    - getStaticProps (prerender = true, default) → HTML generated at build
    - getServerSideProps (prerender = false) → HTML generated per request

  Why server-side here?
    1. The service role key (bypasses RLS) must stay on the server
    2. POST handling (approve/reject) needs server-side logic
    3. Password check happens server-side so it can't be bypassed
*/
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { createClient } from '@supabase/supabase-js';
import { platformDisplayNames, platformColours } from '../lib/types';
import type { Shop } from '../lib/types';

const ADMIN_PASSWORD = (env as any).ADMIN_PASSWORD ?? import.meta.env.ADMIN_PASSWORD;
const serviceRoleKey = (env as any).SUPABASE_SERVICE_ROLE_KEY ?? import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
const supabaseUrl = (env as any).PUBLIC_SUPABASE_URL ?? import.meta.env.PUBLIC_SUPABASE_URL;

if (!ADMIN_PASSWORD || !serviceRoleKey) {
  return new Response('Admin not configured', { status: 503 });
}

const supabaseAdmin = createClient(supabaseUrl, serviceRoleKey);

// Check for password in cookie (set after login)
const cookie = Astro.request.headers.get('cookie') ?? '';
const isAuthenticated = cookie.includes(`kot_admin=${ADMIN_PASSWORD}`);

let message = '';
let messageType: 'success' | 'error' | '' = '';

// Handle POST requests (login, approve, reject)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'login') {
    const password = formData.get('password') as string;
    if (password === ADMIN_PASSWORD) {
      // Set a cookie so they don't have to re-enter the password
      // HttpOnly prevents JS access, SameSite prevents CSRF
      return new Response(null, {
        status: 302,
        headers: {
          'Location': '/admin',
          'Set-Cookie': `kot_admin=${ADMIN_PASSWORD}; Path=/admin; HttpOnly; SameSite=Strict; Max-Age=86400`,
        },
      });
    } else {
      message = 'Wrong password.';
      messageType = 'error';
    }
  }

  if (action === 'approve' && isAuthenticated) {
    const shopId = formData.get('shop_id') as string;
    const { error } = await supabaseAdmin
      .from('shops')
      .update({ status: 'approved' })
      .eq('id', shopId);
    message = error ? `Error: ${error.message}` : 'Shop approved!';
    messageType = error ? 'error' : 'success';
  }

  if (action === 'reject' && isAuthenticated) {
    const shopId = formData.get('shop_id') as string;
    const { error } = await supabaseAdmin
      .from('shops')
      .update({ status: 'rejected' })
      .eq('id', shopId);
    message = error ? `Error: ${error.message}` : 'Shop rejected.';
    messageType = error ? 'error' : 'success';
  }

  if (action === 'approve_review' && isAuthenticated) {
    const reviewId = formData.get('review_id') as string;
    const { error } = await supabaseAdmin
      .from('reviews')
      .update({ status: 'approved' })
      .eq('id', reviewId);
    message = error ? `Error: ${error.message}` : 'Review approved!';
    messageType = error ? 'error' : 'success';
  }

  if (action === 'reject_review' && isAuthenticated) {
    const reviewId = formData.get('review_id') as string;
    const { error } = await supabaseAdmin
      .from('reviews')
      .update({ status: 'rejected' })
      .eq('id', reviewId);
    message = error ? `Error: ${error.message}` : 'Review rejected.';
    messageType = error ? 'error' : 'success';
  }
}

// Fetch pending shops (only if authenticated)
let pendingShops: Shop[] = [];
let pendingReviews: any[] = [];
let approvedCount = 0;
let pendingCount = 0;

if (isAuthenticated) {
  const { data: pending } = await supabaseAdmin
    .from('shops')
    .select('*')
    .eq('status', 'pending')
    .order('created_at', { ascending: true });

  pendingShops = (pending ?? []) as Shop[];

  const { count: approved } = await supabaseAdmin
    .from('shops')
    .select('*', { count: 'exact', head: true })
    .eq('status', 'approved');

  const { count: pendingTotal } = await supabaseAdmin
    .from('shops')
    .select('*', { count: 'exact', head: true })
    .eq('status', 'pending');

  approvedCount = approved ?? 0;
  pendingCount = pendingTotal ?? 0;

  // Fetch pending reviews with shop name
  const { data: pendingReviewData } = await supabaseAdmin
    .from('reviews')
    .select('*, shops(name)')
    .eq('status', 'pending')
    .order('created_at', { ascending: true });

  pendingReviews = (pendingReviewData ?? []) as any[];
}
---

<BaseLayout title="Admin">
  <section class="max-w-4xl mx-auto px-4 py-12">

    {!isAuthenticated ? (
      <!-- Login form -->
      <div class="max-w-sm mx-auto">
        <h1 class="text-2xl font-bold mb-6 text-center">Admin Login</h1>

        {message && messageType === 'error' && (
          <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-sm text-red-700 mb-4">
            {message}
          </div>
        )}

        <form method="POST">
          <input type="hidden" name="action" value="login" />
          <div class="mb-4">
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500"
              required
              autofocus
            />
          </div>
          <button
            type="submit"
            class="w-full py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition"
          >
            Sign in
          </button>
        </form>
      </div>
    ) : (
      <!-- Admin dashboard -->
      <div>
        <div class="flex items-center justify-between mb-8">
          <h1 class="text-2xl font-bold">Admin Dashboard</h1>
          <div class="flex gap-4 text-sm">
            <span class="px-3 py-1 bg-amber-100 text-amber-800 rounded-full font-medium">
              {pendingCount} pending
            </span>
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full font-medium">
              {approvedCount} approved
            </span>
          </div>
        </div>

        {message && (
          <div class={`rounded-lg p-3 text-sm mb-6 ${
            messageType === 'success'
              ? 'bg-green-50 border border-green-200 text-green-700'
              : 'bg-red-50 border border-red-200 text-red-700'
          }`}>
            {message}
          </div>
        )}

        {pendingShops.length === 0 ? (
          <div class="text-center py-12 text-gray-500">
            <p class="text-lg">No shops waiting for review.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-200 text-left text-xs uppercase tracking-wide text-gray-500">
                  <th class="pb-3 pr-3">Shop</th>
                  <th class="pb-3 pr-3">Platform</th>
                  <th class="pb-3 pr-3">Category</th>
                  <th class="pb-3 pr-3">URL</th>
                  <th class="pb-3 pr-3">Source</th>
                  <th class="pb-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {pendingShops.map(shop => {
                  let faviconUrl = '';
                  try {
                    const domain = new URL(shop.shop_url).hostname;
                    faviconUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=32`;
                  } catch {}

                  return (
                    <tr class="hover:bg-gray-50 group">
                      <td class="py-3 pr-3">
                        <div class="flex items-center gap-2">
                          {faviconUrl && (
                            <img src={faviconUrl} alt="" width="20" height="20" class="w-5 h-5 rounded bg-gray-100 flex-shrink-0" loading="lazy" />
                          )}
                          <div>
                            <span class="font-medium text-gray-900">{shop.name}</span>
                            {shop.description && (
                              <p class="text-xs text-gray-500 truncate max-w-[250px]" title={shop.description}>{shop.description}</p>
                            )}
                          </div>
                        </div>
                      </td>
                      <td class="py-3 pr-3">
                        <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${platformColours[shop.platform] ?? 'bg-slate-100 text-slate-800'}`}>
                          {platformDisplayNames[shop.platform]}
                        </span>
                      </td>
                      <td class="py-3 pr-3 text-gray-600">{shop.category}</td>
                      <td class="py-3 pr-3">
                        <a href={shop.shop_url} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline truncate block max-w-[200px]" title={shop.shop_url}>
                          {new URL(shop.shop_url).hostname.replace('www.', '')}{new URL(shop.shop_url).pathname.slice(0, 20)}
                        </a>
                      </td>
                      <td class="py-3 pr-3 text-xs text-gray-400">{shop.submitted_by ?? 'user'}</td>
                      <td class="py-3 text-right whitespace-nowrap">
                        <div class="flex gap-2 justify-end">
                          <form method="POST" class="inline">
                            <input type="hidden" name="action" value="approve" />
                            <input type="hidden" name="shop_id" value={shop.id} />
                            <button type="submit" class="px-3 py-1.5 bg-green-600 text-white text-xs rounded-lg font-medium hover:bg-green-700 transition">
                              Approve
                            </button>
                          </form>
                          <form method="POST" class="inline">
                            <input type="hidden" name="action" value="reject" />
                            <input type="hidden" name="shop_id" value={shop.id} />
                            <button type="submit" class="px-3 py-1.5 bg-red-600 text-white text-xs rounded-lg font-medium hover:bg-red-700 transition">
                              Reject
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}

        <!-- Review moderation -->
        <div class="mt-12">
          <h2 class="text-xl font-bold mb-4">Pending Reviews ({pendingReviews.length})</h2>

          {pendingReviews.length === 0 ? (
            <p class="text-gray-500 text-sm">No reviews waiting for moderation.</p>
          ) : (
            <div class="space-y-4">
              {pendingReviews.map((review: any) => (
                <div class="bg-white border border-gray-200 rounded-xl p-5">
                  <div class="flex items-start justify-between mb-2">
                    <div>
                      <span class="font-medium text-sm">{review.display_name}</span>
                      <span class="text-amber-500 text-sm ml-2">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}</span>
                      <span class="text-xs text-gray-400 ml-2">on {review.shops?.name ?? 'Unknown shop'}</span>
                    </div>
                    <time class="text-xs text-gray-400">
                      {new Date(review.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}
                    </time>
                  </div>
                  <p class="text-sm text-gray-700 mb-4">{review.body}</p>
                  <div class="flex gap-3">
                    <form method="POST" class="inline">
                      <input type="hidden" name="action" value="approve_review" />
                      <input type="hidden" name="review_id" value={review.id} />
                      <button type="submit" class="px-4 py-2 bg-green-600 text-white text-sm rounded-lg font-medium hover:bg-green-700 transition">
                        Approve
                      </button>
                    </form>
                    <form method="POST" class="inline">
                      <input type="hidden" name="action" value="reject_review" />
                      <input type="hidden" name="review_id" value={review.id} />
                      <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm rounded-lg font-medium hover:bg-red-700 transition">
                        Reject
                      </button>
                    </form>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
