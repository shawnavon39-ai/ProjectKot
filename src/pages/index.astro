---
/*
  index.astro — the homepage.

  prerender = false means this page runs on the server per request
  (as a Cloudflare Worker at the edge). This is equivalent to
  getServerSideProps in Next.js. The browser never sees the query,
  only the rendered HTML result.

  Server-rendering is the right choice here because:
    1. New shops appear immediately after admin approval (no rebuild needed)
    2. Cloudflare Workers are fast (~50ms at the edge)
    3. The env vars are available at runtime (not just build time)
*/
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ShopCard from '../components/ShopCard.astro';
import SearchBar from '../components/SearchBar';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../lib/supabase';
import { platformDisplayNames, platformColours } from '../lib/types';
import type { Shop } from '../lib/types';

const supabase = getSupabase(env);

const { data: featuredShops } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .order('created_at', { ascending: false })
  .limit(4);

const shops = (featuredShops ?? []) as Shop[];

const platforms = Object.entries(platformDisplayNames).map(([key, name]) => ({
  key: key as Shop['platform'],
  name,
  colour: platformColours[key as Shop['platform']],
}));
---

<BaseLayout title="Discover Creator Shops">
  <section class="max-w-7xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      Every creator shop.<br />
      <span class="text-blue-600">One place.</span>
    </h1>
    <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
      Discover and follow shops from TikTok, Instagram, YouTube, Pinterest, and Amazon — all in one directory.
    </p>

    <div class="mt-8 max-w-xl mx-auto">
      <SearchBar client:only="react" />
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 pb-8">
    <div class="flex flex-wrap gap-2 justify-center mb-3">
      {platforms.map(p => (
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${p.colour}`}>
          {p.name}
        </span>
      ))}
    </div>
    <div class="flex flex-wrap gap-2 justify-center">
      <a href="/category/fashion" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Fashion</a>
      <a href="/category/beauty" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Beauty</a>
      <a href="/category/tech" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Tech</a>
      <a href="/category/home" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Home</a>
      <a href="/category/fitness" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Fitness</a>
      <a href="/category/food-drink" class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-gray-200">Food & Drink</a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold mb-6">Featured Shops</h2>
    {shops.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {shops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">No shops yet — be the first to submit one.</p>
    )}
  </section>

  <section class="max-w-7xl mx-auto px-4 pb-16 text-center">
    <div class="bg-blue-50 rounded-2xl p-8">
      <h2 class="text-2xl font-bold">Got a shop? List it free.</h2>
      <p class="mt-2 text-gray-600">Sellers can submit their shop to be featured in our directory.</p>
      <a href="/submit" class="inline-block mt-4 px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition">
        Submit Your Shop
      </a>
    </div>
  </section>
</BaseLayout>
