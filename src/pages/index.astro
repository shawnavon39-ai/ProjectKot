---
/*
  index.astro — the homepage.

  prerender = false means this page runs on the server per request
  (as a Cloudflare Worker at the edge). This is equivalent to
  getServerSideProps in Next.js. The browser never sees the query,
  only the rendered HTML result.

  Server-rendering is the right choice here because:
    1. New shops appear immediately after admin approval (no rebuild needed)
    2. Cloudflare Workers are fast (~50ms at the edge)
    3. The env vars are available at runtime (not just build time)
*/
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ShopCard from '../components/ShopCard.astro';
import AdUnit from '../components/AdUnit.astro';
import EmailSignup from '../components/EmailSignup';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../lib/supabase';
import type { Shop } from '../lib/types';

const supabase = getSupabase(env);

const { data: featuredShops } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .order('created_at', { ascending: false })
  .limit(4);

const shops = (featuredShops ?? []) as Shop[];

// Trending: most clicked shops (needs clicks column)
const { data: trendingData } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .gt('clicks', 0)
  .order('clicks', { ascending: false })
  .limit(4);

const trendingShops = (trendingData ?? []) as Shop[];

// Shop of the Day: date-based overrides, falls back to deterministic rotation
const FEATURED_OVERRIDES: Record<string, string> = {
  '2026-03-29': 'allie-hunter',
};

const today = new Date();
const todayKey = today.toISOString().slice(0, 10);
const overrideSlug = FEATURED_OVERRIDES[todayKey];

let shopOfTheDay: Shop | null = null;

if (overrideSlug) {
  const { data: featuredShopData } = await supabase
    .from('shops')
    .select('*')
    .eq('slug', overrideSlug)
    .eq('status', 'approved')
    .single();
  shopOfTheDay = (featuredShopData as Shop) ?? null;
}

if (!shopOfTheDay) {
  const { data: allApproved } = await supabase
    .from('shops')
    .select('*')
    .eq('status', 'approved')
    .order('created_at', { ascending: true });

  const approvedList = (allApproved ?? []) as Shop[];
  const dayIndex = (today.getFullYear() * 366 + today.getMonth() * 31 + today.getDate()) % (approvedList.length || 1);
  shopOfTheDay = approvedList.length > 0 ? approvedList[dayIndex] : null;
}

const { data: dealsData } = await supabase
  .from('products')
  .select('*, shop:shops(name, slug, platform)')
  .eq('on_sale', true)
  .order('created_at', { ascending: false })
  .limit(4);

const deals = (dealsData ?? []) as any[];

---

<BaseLayout title="Discover Creator Shops">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Pick Your Shop",
    "url": "https://pickyour.shop",
    "description": "The best creator shops from TikTok, Amazon, Instagram and more — curated, rated, and easy to browse.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://pickyour.shop/shops?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 pt-12 pb-10 text-center">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-5xl text-slate-900">
      Find your next <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">favourite shop</span>
    </h1>
    <p class="mt-3 text-base text-slate-600 max-w-xl mx-auto">
      Creator shops from TikTok, Amazon, Instagram and more — curated, rated, and easy to browse.
    </p>

    <div class="mt-6 flex flex-wrap gap-3 justify-center">
      <a href="/shops" class="px-5 py-2.5 bg-violet-600 text-white rounded-lg text-sm font-semibold hover:bg-violet-700 transition shadow-sm">Browse All Shops</a>
      <a href="/deals" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-semibold hover:border-violet-400 hover:text-violet-600 transition shadow-sm">View Deals</a>
      <a href="/lists" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-semibold hover:border-violet-400 hover:text-violet-600 transition shadow-sm">Curated Lists</a>
    </div>
  </section>

  <!-- Current Deals -->
  {deals.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 pb-10">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">
          🔥 <span class="text-red-500">Current Deals</span>
        </h2>
        <a href="/deals" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all deals →</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {deals.map((product: any) => {
          const pct = product.price && product.original_price
            ? Math.round((1 - product.price / product.original_price) * 100)
            : null;
          return (
            <a
              href={product.product_url}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="relative bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-200 group flex flex-col"
            >
              {/* Top accent bar */}
              <div class="h-1 bg-gradient-to-r from-red-500 to-orange-400" />
              <div class="p-4 flex flex-col flex-1">
                {pct && (
                  <div class="mb-3">
                    <span class="inline-flex items-center gap-1 text-xs font-bold px-2.5 py-1 bg-red-500 text-white rounded-full">
                      -{pct}% OFF
                    </span>
                  </div>
                )}
                <p class="text-sm font-semibold text-slate-900 group-hover:text-violet-600 transition line-clamp-2 mb-auto">{product.name}</p>
                <p class="text-xs text-slate-400 mt-2 mb-3">via {product.shop?.name}</p>
                <div class="flex items-baseline gap-2 flex-wrap">
                  {product.price && <span class="text-lg font-extrabold text-slate-900">£{Number(product.price).toFixed(2)}</span>}
                  {product.original_price && <span class="text-sm text-slate-400 line-through">£{Number(product.original_price).toFixed(2)}</span>}
                </div>
                {pct && product.original_price && product.price && (
                  <p class="text-xs text-green-600 font-medium mt-1">Save £{(Number(product.original_price) - Number(product.price)).toFixed(2)}</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Shop of the Day -->
  {shopOfTheDay && (
    <section class="max-w-7xl mx-auto px-4 pb-10">
      <div class="bg-gradient-to-r from-violet-50 to-indigo-50 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4 border border-violet-100">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-violet-600 flex items-center justify-center">
          <span class="text-white text-xl font-bold">★</span>
        </div>
        <div class="flex-grow">
          <p class="text-xs font-semibold uppercase tracking-wide text-violet-600 mb-1">Shop of the Day</p>
          <a href={`/shops/${shopOfTheDay.slug}`} class="text-xl font-bold text-slate-900 hover:text-violet-600 transition">{shopOfTheDay.name}</a>
          <p class="text-sm text-slate-600 mt-1">{shopOfTheDay.description}</p>
        </div>
        <a href={`/go/${shopOfTheDay.slug}`} class="flex-shrink-0 px-5 py-2.5 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700 transition">
          Visit Shop →
        </a>
      </div>
    </section>
  )}

  <!-- Featured Shops -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900">Featured Shops</h2>
      <a href="/shops" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
    </div>
    {shops.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {shops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    ) : (
      <p class="text-slate-500">No shops yet — be the first to submit one.</p>
    )}
  </section>

  <!-- Ad between sections -->
  <section class="max-w-7xl mx-auto px-4 pb-8">
    <AdUnit />
  </section>

  <!-- Trending Shops -->
  {trendingShops.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">
          <span class="text-amber-500">Trending</span> Shops
        </h2>
        <a href="/shops" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {trendingShops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    </section>
  )}

  <!-- Email capture -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="bg-gradient-to-r from-violet-600 to-indigo-600 rounded-2xl p-8 sm:p-10 text-center text-white">
      <h2 class="text-2xl font-bold mb-2">New shops added every week</h2>
      <p class="text-violet-200 mb-6 text-sm">Get the best new creator shops delivered to your inbox. No spam, unsubscribe anytime.</p>
      <div class="max-w-md mx-auto [&_input]:text-slate-900 [&_button]:bg-white [&_button]:text-violet-700 [&_button]:hover:bg-violet-50">
        <EmailSignup client:only="react" />
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-slate-900 text-center mb-8">How It Works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-100 text-violet-600 flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
        <h3 class="font-semibold text-slate-900 mb-1">Browse or Search</h3>
        <p class="text-sm text-slate-600">Filter by platform, category, or search for shops by name.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-100 text-violet-600 flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
        <h3 class="font-semibold text-slate-900 mb-1">Discover & Compare</h3>
        <p class="text-sm text-slate-600">Read reviews, check ratings, and find creators you'll love.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-100 text-violet-600 flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
        <h3 class="font-semibold text-slate-900 mb-1">Visit & Shop</h3>
        <p class="text-sm text-slate-600">Click through to the creator's shop and start shopping.</p>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-7xl mx-auto px-4 pb-16 text-center">
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-10">
      <h2 class="text-2xl font-bold text-slate-900">Run a shop? Get discovered.</h2>
      <p class="mt-2 text-slate-600">Join hundreds of creators already listed. It takes 30 seconds.</p>
      <a href="/submit" class="inline-block mt-5 px-6 py-3 bg-violet-600 text-white rounded-lg font-semibold hover:bg-violet-700 transition shadow-sm">
        List Your Shop — Free
      </a>
    </div>
  </section>
</BaseLayout>
