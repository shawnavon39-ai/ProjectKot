---
/*
  index.astro — the homepage.

  prerender = false means this page runs on the server per request
  (as a Cloudflare Worker at the edge). This is equivalent to
  getServerSideProps in Next.js. The browser never sees the query,
  only the rendered HTML result.

  Server-rendering is the right choice here because:
    1. New shops appear immediately after admin approval (no rebuild needed)
    2. Cloudflare Workers are fast (~50ms at the edge)
    3. The env vars are available at runtime (not just build time)
*/
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ShopCard from '../components/ShopCard.astro';
import SearchBar from '../components/SearchBar';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../lib/supabase';
import { platformDisplayNames, platformColours } from '../lib/types';
import type { Shop } from '../lib/types';

const supabase = getSupabase(env);

const { data: featuredShops } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .order('created_at', { ascending: false })
  .limit(4);

const shops = (featuredShops ?? []) as Shop[];

// Trending: most clicked shops (needs clicks column)
const { data: trendingData } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .gt('clicks', 0)
  .order('clicks', { ascending: false })
  .limit(4);

const trendingShops = (trendingData ?? []) as Shop[];

// New this week: approved in the last 7 days
const oneWeekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
const { data: newData } = await supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .gte('created_at', oneWeekAgo)
  .order('created_at', { ascending: false })
  .limit(4);

const newShops = (newData ?? []) as Shop[];

// Shop of the Day: date-based overrides, falls back to deterministic rotation
const FEATURED_OVERRIDES: Record<string, string> = {
  '2026-03-29': 'allie-hunter',
};

const today = new Date();
const todayKey = today.toISOString().slice(0, 10);
const overrideSlug = FEATURED_OVERRIDES[todayKey];

let shopOfTheDay: Shop | null = null;

if (overrideSlug) {
  const { data: featuredShopData } = await supabase
    .from('shops')
    .select('*')
    .eq('slug', overrideSlug)
    .eq('status', 'approved')
    .single();
  shopOfTheDay = (featuredShopData as Shop) ?? null;
}

if (!shopOfTheDay) {
  const { data: allApproved } = await supabase
    .from('shops')
    .select('*')
    .eq('status', 'approved')
    .order('created_at', { ascending: true });

  const approvedList = (allApproved ?? []) as Shop[];
  const dayIndex = (today.getFullYear() * 366 + today.getMonth() * 31 + today.getDate()) % (approvedList.length || 1);
  shopOfTheDay = approvedList.length > 0 ? approvedList[dayIndex] : null;
}

const platforms = Object.entries(platformDisplayNames).map(([key, name]) => ({
  key: key as Shop['platform'],
  name,
  colour: platformColours[key as Shop['platform']],
}));
---

<BaseLayout title="Discover Creator Shops">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Pick Your Shop",
    "url": "https://pickyour.shop",
    "description": "The best creator shops from TikTok, Amazon, Instagram and more — curated, rated, and easy to browse.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://pickyour.shop/shops?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 pt-20 pb-16 text-center">
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-6xl text-slate-900">
      Find your next<br />
      <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">favourite shop.</span>
    </h1>
    <p class="mt-5 text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
      The best creator shops from TikTok, Amazon, Instagram and more — curated, rated, and easy to browse.
    </p>

    <div class="mt-10 max-w-xl mx-auto">
      <SearchBar supabaseUrl={env.PUBLIC_SUPABASE_URL} supabaseAnonKey={env.PUBLIC_SUPABASE_ANON_KEY} client:only="react" />
    </div>

    <!-- Platform + category pills -->
    <div class="mt-8 flex flex-wrap gap-2 justify-center">
      {platforms.map(p => (
        <a href={`/shops?platform=${p.key}`} class={`px-3 py-1 rounded-full text-sm font-medium ${p.colour} hover:opacity-80 transition`}>
          {p.name}
        </a>
      ))}
    </div>
    <div class="mt-3 flex flex-wrap gap-2 justify-center">
      <a href="/category/fashion" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Fashion</a>
      <a href="/category/beauty" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Beauty</a>
      <a href="/category/tech" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Tech</a>
      <a href="/category/home" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Home</a>
      <a href="/category/fitness" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Fitness</a>
      <a href="/category/food-drink" class="px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">Food & Drink</a>
    </div>
  </section>

  <!-- Shop of the Day -->
  {shopOfTheDay && (
    <section class="max-w-7xl mx-auto px-4 pb-10">
      <div class="bg-gradient-to-r from-violet-50 to-indigo-50 rounded-2xl p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4 border border-violet-100">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-violet-600 flex items-center justify-center">
          <span class="text-white text-xl font-bold">★</span>
        </div>
        <div class="flex-grow">
          <p class="text-xs font-semibold uppercase tracking-wide text-violet-600 mb-1">Shop of the Day</p>
          <a href={`/shops/${shopOfTheDay.slug}`} class="text-xl font-bold text-slate-900 hover:text-violet-600 transition">{shopOfTheDay.name}</a>
          <p class="text-sm text-slate-600 mt-1">{shopOfTheDay.description}</p>
        </div>
        <a href={`/go/${shopOfTheDay.slug}`} class="flex-shrink-0 px-5 py-2.5 bg-violet-600 text-white rounded-lg text-sm font-medium hover:bg-violet-700 transition">
          Visit Shop →
        </a>
      </div>
    </section>
  )}

  <!-- Featured Shops -->
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900">Featured Shops</h2>
      <a href="/shops" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
    </div>
    {shops.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {shops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    ) : (
      <p class="text-slate-500">No shops yet — be the first to submit one.</p>
    )}
  </section>

  <!-- Trending Shops -->
  {trendingShops.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">
          <span class="text-amber-500">Trending</span> Shops
        </h2>
        <a href="/shops" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {trendingShops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    </section>
  )}

  <!-- New This Week -->
  {newShops.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 pb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">
          <span class="text-violet-600">New</span> This Week
        </h2>
        <a href="/shops" class="text-sm text-violet-600 hover:text-violet-700 font-medium transition">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {newShops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="max-w-7xl mx-auto px-4 pb-16 text-center">
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-10">
      <h2 class="text-2xl font-bold text-slate-900">Run a shop? Get discovered.</h2>
      <p class="mt-2 text-slate-600">Join hundreds of creators already listed. It takes 30 seconds.</p>
      <a href="/submit" class="inline-block mt-5 px-6 py-3 bg-violet-600 text-white rounded-lg font-semibold hover:bg-violet-700 transition shadow-sm">
        List Your Shop — Free
      </a>
    </div>
  </section>
</BaseLayout>
