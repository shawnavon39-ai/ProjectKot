---
/*
  blog/index.astro — lists all blog posts, newest first.

  Uses Astro's Content Collections API:
    getCollection('blog') returns all Markdown files from src/content/blog/
    with their frontmatter validated against the schema in content.config.ts.

  This is prerendered (static HTML at build time) because blog posts
  only change when you push new Markdown files — no need for SSR.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryColours: Record<string, string> = {
  fashion: 'bg-pink-100 text-pink-800',
  beauty: 'bg-purple-100 text-purple-800',
  home: 'bg-amber-100 text-amber-800',
  tech: 'bg-blue-100 text-blue-800',
  lifestyle: 'bg-green-100 text-green-800',
  guides: 'bg-gray-100 text-gray-800',
};
---

<BaseLayout
  title="Blog"
  description="Tips, roundups, and guides for discovering the best creator shops across TikTok, Amazon, Instagram, and more."
>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-2">Blog</h1>
    <p class="text-gray-600 mb-8">Roundups, guides, and tips for finding the best creator shops.</p>

    {posts.length > 0 ? (
      <div class="space-y-6">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="block bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-300 hover:shadow-sm transition">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold mb-1">{post.data.title}</h2>
                <p class="text-gray-600 text-sm mb-3">{post.data.description}</p>
                <div class="flex items-center gap-3 text-xs text-gray-500">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                  <span class={`px-2 py-0.5 rounded-full font-medium ${categoryColours[post.data.category] ?? 'bg-gray-100 text-gray-800'}`}>
                    {post.data.category}
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-500">No posts yet — check back soon.</p>
    )}
  </section>
</BaseLayout>
