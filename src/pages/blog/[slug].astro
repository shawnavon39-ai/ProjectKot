---
/*
  blog/[...slug].astro — renders an individual blog post.

  Uses Astro's Content Collections:
    getCollection('blog')  → all posts (for getStaticPaths)
    post.render()          → converts Markdown to HTML

  The [...slug] catch-all syntax handles nested paths if needed,
  but for flat blog posts it works the same as [slug].

  Prerendered at build time — each post becomes a static HTML page.
  This is ideal for SEO: fast, cacheable, fully indexable.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryColours: Record<string, string> = {
  fashion: 'bg-pink-100 text-pink-800',
  beauty: 'bg-purple-100 text-purple-800',
  home: 'bg-amber-100 text-amber-800',
  tech: 'bg-blue-100 text-blue-800',
  lifestyle: 'bg-green-100 text-green-800',
  guides: 'bg-gray-100 text-gray-800',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
  "author": { "@type": "Organization", "name": "Pick Your Shop" },
  "publisher": {
    "@type": "Organization",
    "name": "Pick Your Shop",
    "url": "https://pickyour.shop",
  },
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://pickyour.shop" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://pickyour.shop/blog" },
    { "@type": "ListItem", "position": 3, "name": post.data.title },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="max-w-3xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-slate-900 transition">Home</a>
      <span class="mx-2">›</span>
      <a href="/blog" class="hover:text-slate-900 transition">Blog</a>
      <span class="mx-2">›</span>
      <span class="text-slate-900">{post.data.title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 mb-3">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${categoryColours[post.data.category] ?? 'bg-slate-100 text-slate-800'}`}>
          {post.data.category}
        </span>
      </div>
    </header>

    <div class="prose prose-slate max-w-none">
      <Content />
    </div>

    <AdUnit />

    <!-- CTA -->
    <div class="mt-12 bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-100 rounded-xl p-6 text-center">
      <h2 class="text-lg font-bold text-slate-900 mb-1">Discover more creator shops</h2>
      <p class="text-slate-600 text-sm mb-4">Browse our full directory of shops across every platform.</p>
      <a href="/shops" class="inline-block px-5 py-2.5 bg-violet-600 text-white rounded-lg font-medium hover:bg-violet-700 transition shadow-sm">
        Browse Shops
      </a>
    </div>
  </article>
</BaseLayout>
