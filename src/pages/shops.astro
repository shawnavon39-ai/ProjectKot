---
/*
  shops.astro — the /shops browse page.

  Server-rendered so newly approved shops appear immediately.
  Now includes both platform and category filters.
*/
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ShopCard from '../components/ShopCard.astro';
import AdUnit from '../components/AdUnit.astro';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../lib/supabase';
import { platformDisplayNames } from '../lib/types';
import type { Shop } from '../lib/types';

const supabase = getSupabase(env);

const url = new URL(Astro.request.url);
const activePlatform = url.searchParams.get('platform');
const activeSort = url.searchParams.get('sort') ?? 'newest';

let query = supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved');

if (activePlatform) {
  query = query.eq('platform', activePlatform);
}

if (activeSort === 'rating') {
  query = query.order('avg_rating', { ascending: false });
} else if (activeSort === 'popular') {
  query = query.order('clicks', { ascending: false });
} else {
  query = query.order('created_at', { ascending: false });
}

const { data } = await query;

const shops = (data ?? []) as Shop[];

const categories = [
  ['fashion', 'Fashion'],
  ['beauty', 'Beauty'],
  ['tech', 'Tech'],
  ['home', 'Home'],
  ['food-drink', 'Food & Drink'],
  ['fitness', 'Fitness'],
] as const;
---

<BaseLayout title="Browse Shops" description="Discover creator shops across TikTok, Instagram, YouTube, Pinterest, and Amazon — all in one directory.">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Browse Shops</h1>
    <p class="text-slate-600 mb-8">Discover creator shops across every platform.</p>

    <!-- Platform filter -->
    <div class="mb-3">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Platform</span>
    </div>
    <div class="flex flex-wrap gap-2 mb-6">
      <a href="/shops" class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${!activePlatform ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>All</a>
      {Object.entries(platformDisplayNames).map(([key, name]) => (
        <a href={`/shops?platform=${key}`} class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${activePlatform === key ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>
          {name}
        </a>
      ))}
    </div>

    <!-- Category filter -->
    <div class="mb-3">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Category</span>
    </div>
    <div class="flex flex-wrap gap-2 mb-8">
      {categories.map(([slug, name]) => (
        <a href={`/category/${slug}`} class="px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">
          {name}
        </a>
      ))}
    </div>

    <AdUnit className="mb-8" />

    <!-- Sort controls -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-sm text-slate-500">{shops.length} shop{shops.length !== 1 ? 's' : ''}</p>
      <div class="flex gap-2">
        {[
          { value: 'newest', label: 'Newest' },
          { value: 'rating', label: 'Top Rated' },
          { value: 'popular', label: 'Most Clicked' },
        ].map(({ value, label }) => {
          const params = new URLSearchParams(url.searchParams);
          params.set('sort', value);
          return (
            <a
              href={`/shops?${params.toString()}`}
              class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${activeSort === value ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}
            >
              {label}
            </a>
          );
        })}
      </div>
    </div>

    {shops.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {shops.map(shop => (
          <ShopCard shop={shop} />
        ))}
      </div>
    ) : (
      <p class="text-slate-500">No shops found.</p>
    )}

    <AdUnit className="mt-8" />
  </section>
</BaseLayout>
