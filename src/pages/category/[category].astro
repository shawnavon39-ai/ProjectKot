---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopCard from '../../components/ShopCard.astro';
import AdUnit from '../../components/AdUnit.astro';
import { env } from 'cloudflare:workers';
import { getSupabase } from '../../lib/supabase';
import { platformDisplayNames } from '../../lib/types';
import type { Shop } from '../../lib/types';

const supabase = getSupabase(env);
const { category } = Astro.params;

// DB stores the slug directly: 'fashion', 'beauty', 'food-drink', etc.
const categoryLabels: Record<string, string> = {
  fashion: '👗 Fashion',
  beauty: '💄 Beauty',
  tech: '💻 Tech',
  home: '🏠 Home',
  fitness: '💪 Fitness',
  'food-drink': '🍕 Food & Drink',
  other: '✨ Other',
};

const label = categoryLabels[category ?? ''];
if (!label) {
  return Astro.redirect('/shops', 307);
}

const url = new URL(Astro.request.url);
const activePlatform = url.searchParams.get('platform');
const activeSort = url.searchParams.get('sort') ?? 'newest';

// Filter by the slug directly — this is what the DB stores
let query = supabase
  .from('shops')
  .select('*')
  .eq('status', 'approved')
  .eq('category', category);

if (activePlatform) {
  query = query.eq('platform', activePlatform);
}

if (activeSort === 'rating') {
  query = query.order('avg_rating', { ascending: false });
} else if (activeSort === 'popular') {
  query = query.order('clicks', { ascending: false });
} else {
  query = query.order('created_at', { ascending: false });
}

const { data } = await query;
const shops = (data ?? []) as Shop[];

const plainName = label.replace(/^\S+\s/, ''); // strip emoji
---

<BaseLayout
  title={`${label} Shops`}
  description={`Discover the best ${plainName.toLowerCase()} creator shops across TikTok, Instagram, YouTube, Amazon and more.`}
>
  <section class="max-w-7xl mx-auto px-4 py-12">
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-slate-900 transition">Home</a>
      <span class="mx-2">›</span>
      <a href="/shops" class="hover:text-slate-900 transition">Shops</a>
      <span class="mx-2">›</span>
      <span class="text-slate-900">{label}</span>
    </nav>

    <h1 class="text-3xl font-bold text-slate-900 mb-2">{label} Shops</h1>
    <p class="text-slate-600 mb-8">Creator shops in the {plainName.toLowerCase()} category.</p>

    <!-- Other categories -->
    <div class="mb-3">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Browse categories</span>
    </div>
    <div class="flex flex-wrap gap-2 mb-6">
      <a href="/shops" class="px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 transition">All</a>
      {Object.entries(categoryLabels).map(([slug, name]) => (
        <a
          href={`/category/${slug}`}
          class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${slug === category ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}
        >
          {name}
        </a>
      ))}
    </div>

    <!-- Platform filter -->
    <div class="mb-3">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Filter by platform</span>
    </div>
    <div class="flex flex-wrap gap-2 mb-8">
      <a href={`/category/${category}`} class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${!activePlatform ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>All</a>
      {Object.entries(platformDisplayNames).map(([key, name]) => (
        <a href={`/category/${category}?platform=${key}`} class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${activePlatform === key ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}>
          {name}
        </a>
      ))}
    </div>

    <AdUnit className="mb-8" />

    <!-- Sort + count -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-sm text-slate-500">{shops.length} shop{shops.length !== 1 ? 's' : ''}</p>
      <div class="flex gap-2">
        {[
          { value: 'newest', sortLabel: 'Newest' },
          { value: 'rating', sortLabel: 'Top Rated' },
          { value: 'popular', sortLabel: 'Most Clicked' },
        ].map(({ value, sortLabel }) => {
          const params = new URLSearchParams(url.searchParams);
          params.set('sort', value);
          return (
            <a
              href={`/category/${category}?${params.toString()}`}
              class={`px-3 py-1.5 rounded-lg text-sm font-medium transition ${activeSort === value ? 'bg-violet-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}`}
            >
              {sortLabel}
            </a>
          );
        })}
      </div>
    </div>

    {shops.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {shops.map(shop => <ShopCard shop={shop} />)}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-slate-500 text-lg mb-4">No {plainName.toLowerCase()} shops yet.</p>
        <a href="/submit" class="text-violet-600 hover:text-violet-700 font-medium transition">Be the first to submit one →</a>
      </div>
    )}

    <AdUnit className="mt-8" />
  </section>
</BaseLayout>
