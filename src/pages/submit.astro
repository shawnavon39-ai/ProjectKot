---
/*
  submit.astro — the /submit page.

  The page shell (layout, heading, description) is static Astro HTML.
  The form is a React island — it hydrates in the browser so it can
  handle useState, form validation, and Supabase inserts.

  client:load = hydrate immediately when the page loads.
  Other options:
    client:visible = hydrate when scrolled into view (good for below-fold)
    client:idle    = hydrate when browser is idle (good for non-urgent)

  For a form the user will interact with immediately, client:load is correct.
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import SubmitForm from '../components/SubmitForm';
---

<BaseLayout title="List Your Shop">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">List Your Shop</h1>
    <p class="text-slate-600 mb-8">Get your creator shop in front of new customers. Free, takes 30 seconds.</p>

    <SubmitForm client:only="react" />
  </section>
</BaseLayout>
