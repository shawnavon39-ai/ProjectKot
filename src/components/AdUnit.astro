---
/*
  AdUnit.astro — reusable AdSense ad slot.

  Renders a responsive in-article ad unit. Once you have your AdSense
  publisher ID and ad slot ID, replace the placeholder values below.

  Usage:
    <AdUnit />                    — default in-article ad
    <AdUnit slot="1234567890" />  — specific ad slot
*/
interface Props {
  slot?: string;
  format?: string;
  className?: string;
}

const {
  slot: adSlot = "XXXXXXXXXX",
  format = "auto",
  className = "",
} = Astro.props;
---

<div class={`ad-container my-8 text-center ${className}`}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-9414116497549742"
    data-ad-slot={adSlot}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>
