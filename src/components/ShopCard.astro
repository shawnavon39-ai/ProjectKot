---
/*
  ShopCard.astro — static component, renders to HTML at build time.

  Now uses the shared Shop type from lib/types.ts instead of an inline interface.
  The platform slug (e.g. 'tiktok') is mapped to a display name ('TikTok Shop')
  and colour via the shared lookup maps.
*/
import type { Shop } from '../lib/types';
import { platformDisplayNames, platformColours } from '../lib/types';

interface Props {
  shop: Shop;
}

const { shop } = Astro.props;
const displayName = platformDisplayNames[shop.platform];
const colour = platformColours[shop.platform];
---

<a href={`/shops/${shop.slug}`} class="block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition group">
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-semibold text-lg group-hover:text-blue-600 transition">{shop.name}</h3>
    <span class={`text-xs px-2 py-0.5 rounded-full font-medium whitespace-nowrap ${colour}`}>
      {displayName}
    </span>
  </div>
  <p class="text-sm text-gray-600 mb-3">{shop.description}</p>
  <div class="flex items-center gap-3 text-xs text-gray-500">
    <span>{shop.category}</span>
    {shop.followers && (
      <>
        <span>·</span>
        <span>{shop.followers} followers</span>
      </>
    )}
  </div>
</a>
