---
interface Props {
  supabaseUrl: string;
  supabaseAnonKey: string;
}
const { supabaseUrl, supabaseAnonKey } = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 pb-16">
  <div class="bg-gradient-to-r from-violet-600 to-indigo-600 rounded-2xl p-8 sm:p-10 text-center text-white">
    <h2 class="text-2xl font-bold mb-2">New shops added every week</h2>
    <p class="text-violet-200 mb-6 text-sm">Get the best new creator shops delivered to your inbox. No spam, unsubscribe anytime.</p>
    <form id="email-capture-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        id="email-input"
        placeholder="your@email.com"
        required
        class="flex-1 px-4 py-2.5 rounded-lg text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-white"
      />
      <button
        type="submit"
        id="email-submit"
        class="px-5 py-2.5 bg-white text-violet-700 font-semibold rounded-lg text-sm hover:bg-violet-50 transition whitespace-nowrap"
      >
        Notify me
      </button>
    </form>
    <p id="email-message" class="mt-3 text-sm text-violet-200 hidden"></p>
  </div>
</section>

<script define:vars={{ supabaseUrl, supabaseAnonKey }}>
  const form = document.getElementById('email-capture-form');
  const input = document.getElementById('email-input');
  const submit = document.getElementById('email-submit');
  const message = document.getElementById('email-message');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = input.value.trim();
    if (!email) return;

    submit.disabled = true;
    submit.textContent = 'Saving...';

    const res = await fetch(`${supabaseUrl}/rest/v1/subscribers`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': supabaseAnonKey,
        'Authorization': `Bearer ${supabaseAnonKey}`,
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify({ email }),
    });

    message.classList.remove('hidden');
    if (res.ok || res.status === 409) {
      form.classList.add('hidden');
      message.textContent = "You're on the list! We'll be in touch.";
      message.classList.remove('text-red-300');
      message.classList.add('text-violet-200');
    } else {
      message.textContent = 'Something went wrong — please try again.';
      message.classList.add('text-red-300');
      submit.disabled = false;
      submit.textContent = 'Notify me';
    }
  });
</script>
