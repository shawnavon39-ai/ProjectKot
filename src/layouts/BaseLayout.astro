---
/*
  BaseLayout.astro — the shared HTML shell for every page.

  Astro equivalent of React's App.tsx wrapper or Next.js _app.tsx.
  Unlike React, this runs ONLY at build time — zero JS shipped.

  Props are typed with Astro.props (like React component props):
*/
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "Discover creator shops across TikTok, Instagram, YouTube, Pinterest and Amazon in one place.",
  ogImage = "/og-default.png",
  ogType = "website",
} = Astro.props;

/*
  Astro.url gives you the full URL of the current page at build time.
  We use it for canonical URLs and Open Graph — both need absolute URLs.
*/
const canonicalUrl = Astro.url.href;
const siteName = "Pick Your Shop";

import '../styles/global.css';
import NavBar from '../components/NavBar';
import EmailSignup from '../components/EmailSignup';

/*
  Pass Supabase config as props to client:only React components.
  import.meta.env works server-side (Astro frontmatter) but NOT in client
  bundles on Cloudflare Pages — Vite can't inline vars that only exist
  at Workers runtime. So we read them here and pass as serialised props.
*/
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL — tells Google "this is THE url for this page" -->
    <link rel="canonical" href={canonicalUrl} />

    <!--
      Open Graph tags — control how the page looks when shared on
      social media (Facebook, LinkedIn, iMessage, Slack, etc.)
      Without these, platforms just show the URL as plain text.
    -->
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <title>{title} | Pick Your Shop</title>

    <!--
      JSON-LD structured data slot — individual pages can inject
      schema.org markup here via the "head" slot.
    -->
    <link rel="alternate" type="application/rss+xml" title="Pick Your Shop Blog" href="/rss.xml" />

    <slot name="head" />

    <!--
      Google AdSense — replace ca-pub-9414116497549742 with your publisher ID
      after approval. The script loads async and won't block page render.
      Remove this comment block once you have a real publisher ID.
    -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9414116497549742" crossorigin="anonymous"></script>

    <!-- Skimlinks — auto-converts outbound links to affiliate links where programmes exist -->
    <script type="text/javascript" src="https://s.skimresources.com/js/300759X1788629.skimlinks.js"></script>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen">
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <NavBar supabaseUrl={supabaseUrl} supabaseAnonKey={supabaseAnonKey} client:only="react" />
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-200 mt-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="max-w-sm mb-8">
          <p class="text-sm font-medium text-slate-700 mb-2">Get notified of new shops</p>
          <EmailSignup client:only="react" />
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
          <span>&copy; {new Date().getFullYear()} Pick Your Shop</span>
          <div class="flex items-center gap-4">
            <a href="/shops" class="hover:text-slate-900 transition">Browse</a>
            <a href="/deals" class="hover:text-slate-900 transition">Deals</a>
            <a href="/lists" class="hover:text-slate-900 transition">Lists</a>
            <a href="/blog" class="hover:text-slate-900 transition">Blog</a>
            <a href="/submit" class="hover:text-slate-900 transition">Submit Shop</a>
            <a href="/submit-deal" class="hover:text-slate-900 transition">Submit Deal</a>
            <a href="/rss.xml" class="hover:text-slate-900 transition">RSS</a>
            <a href="mailto:hello@pickyour.shop?subject=Removal%20Request" class="hover:text-slate-900 transition">Request Removal</a>
          </div>
        </div>
        <div class="mt-4 flex justify-center">
          <a href="https://ko-fi.com/shawnavon" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-50 border border-amber-200 text-amber-700 text-xs font-medium hover:bg-amber-100 transition">
            <span>☕</span> Buy me a coffee
          </a>
        </div>
        <p class="mt-4 text-xs text-slate-400 text-center">
          Pick Your Shop is an independent directory. We are not affiliated with or endorsed by any of the shops listed. All trademarks belong to their respective owners. If you are a shop owner and would like your listing removed, please <a href="mailto:hello@pickyour.shop?subject=Removal%20Request" class="underline hover:text-slate-600 transition">contact us</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
