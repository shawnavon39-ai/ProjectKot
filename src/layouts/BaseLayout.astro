---
/*
  BaseLayout.astro — the shared HTML shell for every page.

  Astro equivalent of React's App.tsx wrapper or Next.js _app.tsx.
  Unlike React, this runs ONLY at build time — zero JS shipped.

  Props are typed with Astro.props (like React component props):
*/
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = "Discover creator shops across TikTok, Instagram, YouTube, Pinterest and Amazon in one place.",
  ogImage = "/og-default.png",
  ogType = "website",
} = Astro.props;

/*
  Astro.url gives you the full URL of the current page at build time.
  We use it for canonical URLs and Open Graph — both need absolute URLs.
*/
const canonicalUrl = Astro.url.href;
const siteName = "Pick Your Shop";

import '../styles/global.css';
import NavBar from '../components/NavBar';

/*
  Pass Supabase config as props to client:only React components.
  import.meta.env works server-side (Astro frontmatter) but NOT in client
  bundles on Cloudflare Pages — Vite can't inline vars that only exist
  at Workers runtime. So we read them here and pass as serialised props.
*/
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL — tells Google "this is THE url for this page" -->
    <link rel="canonical" href={canonicalUrl} />

    <!--
      Open Graph tags — control how the page looks when shared on
      social media (Facebook, LinkedIn, iMessage, Slack, etc.)
      Without these, platforms just show the URL as plain text.
    -->
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <title>{title} | Pick Your Shop</title>

    <!--
      JSON-LD structured data slot — individual pages can inject
      schema.org markup here via the "head" slot.
    -->
    <link rel="alternate" type="application/rss+xml" title="Pick Your Shop Blog" href="/rss.xml" />

    <slot name="head" />
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen">
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <NavBar supabaseUrl={supabaseUrl} supabaseAnonKey={supabaseAnonKey} client:only="react" />
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-200 mt-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>&copy; {new Date().getFullYear()} Pick Your Shop</span>
        <div class="flex items-center gap-4">
          <a href="/shops" class="hover:text-slate-900 transition">Browse</a>
          <a href="/blog" class="hover:text-slate-900 transition">Blog</a>
          <a href="/submit" class="hover:text-slate-900 transition">Submit</a>
          <a href="/rss.xml" class="hover:text-slate-900 transition">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
